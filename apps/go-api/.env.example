ENV=local
WEB_APP_URL=http://localhost:3000
APP_NAME=aura

REDIS_DSN=redis://localhost:6379/0

POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/example?sslmode=disable
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=5
POSTGRES_CONN_MAX_IDLE_TIME=10
POSTGRES_PING_TIMEOUT=5
POSTGRES_AUTO_MIGRATE=true
POSTGRES_MIGRATIONS_PATH=./migrations

SERVER_PORT=1337
SERVER_CORS=http://localhost:3000
SERVER_READ_TIMEOUT=30
SERVER_WRITE_TIMEOUT=30
SERVER_IDLE_TIMEOUT=120
SERVER_BODY_LIMIT=10M

RESEND_API_KEY=resend_api_key
FROM_EMAIL=no-reply@yca.software
FROM_NAME=Example

SUPPORT_INBOX_EMAIL=support@yca.software

TOKEN_ACCESS_SECRET=access_secret
TOKEN_ACCESS_TTL=15
TOKEN_REFRESH_TTL=168
TOKEN_PASSWORD_RESET_TTL=24
TOKEN_INVITATION_TTL=168
TOKEN_EMAIL_VERIFICATION_TTL=168

GOOGLE_OAUTH_CLIENT_ID=xxx
GOOGLE_OAUTH_CLIENT_SECRET=xxx
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/oauth/google
GOOGLE_MAPS_API_KEY=xxx

PADDLE_API_KEY=xxx
PADDLE_WEBHOOK_SECRET=xxx
PADDLE_ENVIRONMENT=sandbox
PADDLE_PRICE_BASIC_MONTHLY=xxx
PADDLE_PRICE_BASIC_ANNUAL=xxx
PADDLE_PRICE_PRO_MONTHLY=xxx
PADDLE_PRICE_PRO_ANNUAL=xxx

JOB_INFRA_MAX_RETRIES=3
JOB_CLEANUP_CONCURRENCY=1
JOB_APPLY_SCHEDLED_PLAN_CHANGES_CONCURRENCY=1

RABBITMQ_URL=amqp://guest:guest@localhost:5672/

CRON_ENABLED=false
CRON_CLEANUP_ARCHIVED_INTERVAL=24h
CRON_APPLY_SCHEDULED_PLAN_CHANGES_INTERVAL=4h