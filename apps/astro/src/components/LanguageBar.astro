---
import type { Locale } from "../i18n/config";
import type { Messages } from "../i18n/loadMessages";

interface Props {
	locale: Locale;
	labels: Messages["languageBar"];
}

const { locale, labels } = Astro.props;

const base = import.meta.env.BASE_URL;
const enHref = base;
const frHref = `${base}fr/`;
---

<div
	class="fixed right-3 top-0 z-[60] flex h-16 items-center gap-2 px-2 text-xs font-medium text-muted-foreground sm:right-4"
	aria-label={labels.label}
>
	<a
		href={enHref}
		class:list={[
			"rounded-md border border-transparent px-2 py-1 transition-colors hover:text-foreground",
			locale === "en" &&
				"border-border/60 bg-background/90 font-semibold text-foreground shadow-sm",
		]}
	>
		{labels.english}
	</a>
	<span aria-hidden="true" class="text-border">
		|
	</span>
	<a
		href={frHref}
		class:list={[
			"rounded-md border border-transparent px-2 py-1 transition-colors hover:text-foreground",
			locale === "fr" &&
				"border-border/60 bg-background/90 font-semibold text-foreground shadow-sm",
		]}
	>
		{labels.french}
	</a>
</div>
